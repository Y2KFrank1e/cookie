<Window x:Class="cookie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   Title="DOUBLE CUP CLICKER"
        Height="600"
        Width="450"
        Background="#111111"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#111111" Offset="0"/>
                <GradientStop Color="#1B0033" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- CUPS -->

            <TextBlock x:Name="CookiesText"
                       Text="CUPS: 0"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="#C77DFF"
                       Margin="10"
                       TextAlignment="Center">

                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      Color="#C77DFF"
                                      ShadowDepth="0"/>
                </TextBlock.Effect>

            </TextBlock>

            <!-- CUP BUTTON -->

            <Button x:Name="CupButton"
                    Width="240"
                    Height="240"
                    FontSize="100"
                    Content="🥤"
                    Background="#2A0A3D"
                    Foreground="White"
                    BorderBrush="#C77DFF"
                    BorderThickness="4"
                    Click="Cookie_Click"
                    RenderTransformOrigin="0.5,0.5">

                <Button.RenderTransform>
                    <RotateTransform x:Name="CupRotate"/>
                </Button.RenderTransform>

                <Button.Effect>
                    <DropShadowEffect BlurRadius="30"
                                      Color="#C77DFF"
                                      ShadowDepth="0"/>
                </Button.Effect>

            </Button>

            <!-- INFO -->

            <TextBlock x:Name="ClickText"
                       Text="DRANK PER CLICK: 1"
                       FontSize="18"
                       Foreground="White"
                       Margin="15"
                       TextAlignment="Center"/>

            <TextBlock x:Name="SecondText"
                       Text="FLOW PER SECOND: 0"
                       FontSize="18"
                       Foreground="White"
                       Margin="5"
                       TextAlignment="Center"/>

            <!-- SHOP -->

            <Button Content="ENTER SHOP"
                    Width="180"
                    Height="50"
                    Margin="20"
                    FontSize="18"
                    FontWeight="Bold"
                    Background="#6A00F4"
                    Foreground="White"
                    BorderThickness="0"
                    Click="OpenShop_Click">

                <Button.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      Color="#C77DFF"
                                      ShadowDepth="0"/>
                </Button.Effect>

            </Button>

            <!-- STATS -->

            <Border Background="#1A1A1A"
                    CornerRadius="15"
                    Padding="15"
                    Margin="10">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="15"
                                      Color="#6A00F4"
                                      ShadowDepth="0"/>
                </Border.Effect>

                <TextBlock x:Name="StatsText"
                           Foreground="White"
                           FontSize="16"/>

            </Border>

        </StackPanel>

    </Grid>
</Window>
